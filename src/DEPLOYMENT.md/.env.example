# ══════════════════════════════════════
#  RemoteAI — Environment Variables
#  Copy to .env and fill in values
# ══════════════════════════════════════

# ── Backend ────────────────────────────
PORT=5000

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Drivers → Node.js
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/remoteai?retryWrites=true&w=majority

# JWT secret (use a strong random string in production)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_in_production

# ── AI (Optional) ──────────────────────
# Google Gemini API — https://aistudio.google.com
# If blank, the app runs in fallback mode (no real AI, but everything else works)
GEMINI_API_KEY=

# ── Frontend (Vite) ────────────────────
# API base URL — used by frontend to call your backend
# Development: http://localhost:5000
# Production:  https://your-backend.railway.app
VITE_API_URL=http://localhost:5000
